    @media (max-width: 980px){ .doDont{grid-template-columns:1fr} }
    .box{
      border-radius: 14px;
      border:1px solid rgba(255,255,255,.12);
      padding:12px;
      background: rgba(255,255,255,.03);
    }
    .box.good{border-color: rgba(52,211,153,.55); background: rgba(52,211,153,.08)}
    .box.bad{border-color: rgba(251,113,133,.55); background: rgba(251,113,133,.06)}
    .mini{font-size:13px; color: rgba(234,242,255,.85)}
    .controls{display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-top:10px;}
    button{
      cursor:pointer;
      border:none;
      padding:10px 14px;
      border-radius: 12px;
      font-weight:900;
      color:#06101a;
      background: linear-gradient(135deg, rgba(77,214,255,.95), rgba(167,139,250,.95));
