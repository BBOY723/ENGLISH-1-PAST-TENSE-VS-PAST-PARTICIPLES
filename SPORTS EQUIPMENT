      color: var(--text);
      background: rgba(255,255,255,.06);
      border:1px solid var(--line);
      box-shadow:none;
    }
    .quizQ{
      margin:10px 0;
      padding:12px;
      border:1px solid var(--line);
      border-radius: 14px;
      background: rgba(255,255,255,.03);
    }
    .prompt{font-weight:900; margin-bottom:8px}
    .opt{
      display:flex; gap:10px; align-items:flex-start;
      padding:10px;
      border-radius: 12px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(0,0,0,.10);
      cursor:pointer;
      user-select:none;
      margin:8px 0;
    }
    .opt:hover{border-color: rgba(77,214,255,.45)}
    .opt input{margin-top:3px}
    .result{
      padding:10px 12px;
      border-radius: 12px;
      border:1px solid var(--line);
      background: rgba(255,255,255,.04);
      font-weight:900;
