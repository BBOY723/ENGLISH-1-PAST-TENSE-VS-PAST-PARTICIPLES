  <script>
    function checkSafetyQuiz(){
      const box = document.getElementById('quizBox');
      const qs = box.querySelectorAll('.quizQ');
      let score = 0;

      qs.forEach(q => {
        const ans = q.dataset.answer;
        const chosen = q.querySelector('input[type="radio"]:checked');
        const ok = chosen && chosen.value === ans;

        q.style.borderColor = ok ? 'rgba(52,211,153,.55)' : 'rgba(251,113,133,.55)';
        q.style.background = ok ? 'rgba(52,211,153,.08)' : 'rgba(251,113,133,.06)';

        if(ok) score++;
      });

      const result = document.getElementById('quizResult');
      result.textContent = `Score: ${score} / ${qs.length}`;

      if(score === qs.length){
        result.className = 'result good';
        result.textContent += ' — Excellent safety knowledge!';
      } else if(score >= Math.ceil(qs.length * 0.6)){
        result.className = 'result';
        result.textContent += ' — Good. Review the Equipment Guide and try again.';
      } else {
        result.className = 'result bad';
        result.textContent += ' — Please read the Manual again and retry.';
      }
    }

    function resetSafetyQuiz(){
      const box = document.getElementById('quizBox');
      box.querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);
      box.querySelectorAll('.quizQ').forEach(q => {
        q.style.borderColor = 'rgba(255,255,255,.12)';
        q.style.background = 'rgba(255,255,255,.03)';
      });
      const result = document.getElementById('quizResult');
      result.className = 'result';
      result.textContent = 'Score: —';
    }
  </script>
