    .badgeRow{display:flex; flex-wrap:wrap; gap:8px; margin-top:10px}
    .badge{
      font-size:13px; font-weight:800;
      padding:6px 10px; border-radius:999px;
      border:1px solid var(--line);
      background: rgba(255,255,255,.04);
    }
    .badge.accent{border-color: rgba(77,214,255,.45)}
    .badge.purple{border-color: rgba(167,139,250,.45)}
    .rule{
      border-left:4px solid rgba(77,214,255,.75);
      padding:10px 12px;
      background: rgba(77,214,255,.06);
      border-radius: 12px;
      margin:10px 0;
    }
    .rule.purple{
      border-left-color: rgba(167,139,250,.85);
      background: rgba(167,139,250,.07);
    }
    .rule.warn{
      border-left-color: rgba(251,191,36,.85);
      background: rgba(251,191,36,.08);
    }
    .list{margin:0; padding-left:18px; color:var(--muted)}
    .kbd{
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 12px;
      padding:2px 6px;
      border-radius: 8px;
      border:1px solid rgba(255,255,255,.18);
      background: rgba(0,0,0,.18);
    }
    .equip{
      border:1px solid var(--line);
      border-radius: 16px;
      background: rgba(0,0,0,.12);
      padding:14px;
    }
    .equipHead{
      display:flex; align-items:flex-start; justify-content:space-between; gap:10px;
      margin-bottom:10px;
    }
    .tag{
      font-size:12px; font-weight:900;
      padding:5px 9px; border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.04);
      white-space:nowrap;
    }
    .tag.safe{border-color: rgba(52,211,153,.55); background: rgba(52,211,153,.10)}
    .tag.care{border-color: rgba(251,191,36,.55); background: rgba(251,191,36,.10)}
    .steps{margin:0; padding-left:18px; color: rgba(234,242,255,.90)}
    .steps li{margin:6px 0}
    .doDont{
      display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px;
